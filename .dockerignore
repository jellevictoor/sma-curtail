# Don't bake secrets, dev caches, or local state into the image
.env
.venv/
.git/
.gitignore
.claude/
.DS_Store
.pytest_cache/
.ruff_cache/
.mypy_cache/
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
htmlcov/
.coverage

# Tests + scripts aren't needed at runtime
tests/
scripts/

# Reference PDF, README, etc. aren't needed at runtime
*.pdf
*.md
docker-compose.yml
.dockerignore
.gitignore
