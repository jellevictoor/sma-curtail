# Copy to .env and fill in INFLUX_TOKEN. Other values default to Jelle's setup.

# --- Inverter (Modbus TCP) ---------------------------------------------------
INVERTER_HOST=192.168.1.3
INVERTER_PORT=502
INVERTER_UNIT_ID=3
# tcp or udp. UDP often more reliable on older SMA firmware (TCP server can hang
# while Speedwire/UDP keeps working). Requires UDP server enabled in inverter UI.
INVERTER_TRANSPORT=tcp

# --- InfluxDB (EPEX prices) -------------------------------------------------
INFLUX_URL=http://192.168.1.5:8086
INFLUX_ORG=victoor.io
INFLUX_BUCKET=energy_prices
INFLUX_METERING_BUCKET=metering
INFLUX_TOKEN=replace-me

# Fluvius region (one of: ANTWERPEN, HALLE_VILVOORDE, IMEWO, KEMPEN, LIMBURG,
# MIDDEN_VLAANDEREN, WEST, ZENNE_DIJLE) — drives the consumption-price math.
FLUVIUS_REGION=WEST

# --- evcc (loadpoint state via MCP) -----------------------------------------
EVCC_MCP_URL=https://evcc.victoor.io/mcp

# --- Curtailment policy -----------------------------------------------------
# Threshold expressed in € per kWh of net Ecopower injection price.
# Defaults: enter just below break-even (~+14 €/MWh EPEX), release at clearly profitable.
ENTER_BELOW_EUR_KWH=-0.001
EXIT_ABOVE_EUR_KWH=0.005

# --- MQTT (HA auto-discovery; leave MQTT_HOST empty to disable) -----------
MQTT_HOST=mqtt.victoor.io
MQTT_PORT=1883
# MQTT_USERNAME=
# MQTT_PASSWORD=
MQTT_DISCOVERY_PREFIX=homeassistant

# --- Solar forecast (forecast.solar; leave SOLAR_LAT empty to disable) -----
SOLAR_LAT=50.99529759340605
SOLAR_LON=3.2131484259319767
SOLAR_DEC=39
SOLAR_AZ=154
SOLAR_KWP=5.4

# --- Docker (only used by docker-compose, not by the daemon itself) -------
# LAN IP of the Docker host where Traefik is listening. Used in extra_hosts to
# map *.victoor.io hostnames inside the container to a reachable address.
# If left unset, falls back to `host-gateway` — that only works when Traefik
# binds to 0.0.0.0 (most setups bind to a specific LAN interface, so set this).
# TRAEFIK_HOST=192.168.1.5

# --- Web server -------------------------------------------------------------
# HTTP port for the FastAPI dashboard. docker-compose publishes this port
# from the container to the host. Defaults to 8080 if unset.
WEB_PORT=8980

# --- Loop / logging ---------------------------------------------------------
# How often the daemon evaluates state and writes Modbus heartbeat. Inverter
# watchdog is 600s, so anything ≤300s is safe; 15s gives snappy UI updates.
TICK_SECONDS=15

# How often to refresh the inverter watchdog when the target hasn't changed.
# Inverter watchdog is 600 s; 300 s gives 2× margin. We otherwise only write
# when the target percent actually changes — reduces flash wear by ~20× vs.
# writing every tick.
MODBUS_HEARTBEAT_SECONDS=300

# EMA smoothing factor for the home_power input (NOT the output setpoint).
# 1.0 = raw, 0.3 = ~3-sample window (≈45 s at 15 s tick), 0.1 = heavier smoothing.
# Avoids match-load target oscillation on transients (washing-machine startup,
# EV inrush, heat-pump cycling).
HOME_POWER_EMA_ALPHA=0.15

# Deadband on the match-load target percent. While curtailing, ignore any
# change smaller than this — keeps the inverter setpoint stable through small
# home-power jitter. 3% ≈ 120 W on a 4 kW inverter.
TARGET_DEADBAND_PERCENT=3
LOG_LEVEL=INFO
